# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/spark_ev

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CONNECT_ENABLED=true

# Firebase (path to service account JSON)
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# Mapbox (passed to frontend, optional on backend)
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token

# App Config
BOOKING_LATE_CANCEL_MINUTES=15
MAX_BOOKING_DURATION_HOURS=4
